# ── Docker Compose (local DB) ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=narrex

# ── API (apps/api) ──
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/narrex
JWT_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/v1/auth/google/callback
WEB_APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# LLM — Cloudflare Workers AI (primary) + Gemini Flash (fallback)
CF_ACCOUNT_ID=
CF_API_TOKEN=
GEMINI_API_KEY=

# ── Web (apps/web) ──
VITE_API_URL=http://localhost:8080
