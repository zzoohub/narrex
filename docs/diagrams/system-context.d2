direction: right

# ── Actors ──────────────────────────────────────────
writer: Writer {
  shape: person
  icon: https://icons.terrastruct.com/essentials%2F359-users.svg
  style.fill: "#f5f0e8"
  style.stroke: "#b08040"
}

# ── System Boundary ─────────────────────────────────
narrex: Narrex {
  style.stroke-dash: 3
  style.fill: "#faf8f4"
  style.stroke: "#b08040"
  style.font-color: "#3d3529"

  editor: Visual Novel Editor {
    style.fill: "#e8dcc8"
    style.stroke: "#b08040"
    style.font-color: "#3d3529"
  }
}

# ── External Systems ────────────────────────────────
llm: LLM Providers {
  style.fill: "#e8e4df"
  style.stroke: "#8a7e6e"
  style.font-color: "#3d3529"

  google: Google AI (Gemini) {
    style.fill: "#d4cfc8"
    style.stroke: "#8a7e6e"
  }
  anthropic: Anthropic (Claude) {
    style.fill: "#d4cfc8"
    style.stroke: "#8a7e6e"
  }
}

auth: Google OAuth2 {
  style.fill: "#e8e4df"
  style.stroke: "#8a7e6e"
  style.font-color: "#3d3529"
}

neon: Neon PostgreSQL {
  shape: cylinder
  style.fill: "#d4dbc8"
  style.stroke: "#7a8a6e"
  style.font-color: "#3d3529"
}

r2: Cloudflare R2 {
  shape: cylinder
  style.fill: "#d4dbc8"
  style.stroke: "#7a8a6e"
  style.font-color: "#3d3529"
}

# ── Connections ─────────────────────────────────────
writer -> narrex.editor: "Story ideas, edits,\ncreative directions" {
  style.stroke: "#b08040"
  style.font-color: "#6b5c3a"
}
narrex.editor -> writer: "Structured timelines,\nAI prose drafts" {
  style.stroke: "#b08040"
  style.font-color: "#6b5c3a"
}

narrex.editor -> llm: "Scene generation,\nauto-structuring,\nsummary compression" {
  style.stroke: "#6b7a8a"
  style.font-color: "#4a5a6a"
}
llm -> narrex.editor: "Streaming tokens (SSE)" {
  style.stroke: "#6b7a8a"
  style.font-color: "#4a5a6a"
  style.stroke-dash: 5
}

narrex.editor -> auth: "OAuth2 flow" {
  style.stroke: "#8a7e6e"
  style.font-color: "#6b5c3a"
}

narrex.editor -> neon: "Projects, nodes,\ncharacters, drafts" {
  style.stroke: "#7a8a6e"
  style.font-color: "#5a6a4a"
}

narrex.editor -> r2: "File imports,\ncharacter images" {
  style.stroke: "#7a8a6e"
  style.font-color: "#5a6a4a"
}
