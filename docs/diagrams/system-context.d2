direction: down

# Actors
writer: Writer {
  shape: person
  style.stroke: "#2563eb"
  style.font-size: 16
}

# External Systems
oauth: OAuth Providers {
  style.stroke: "#9333ea"
  style.border-radius: 8
  google: Google OAuth2
  kakao: Kakao OAuth2
}

llm: LLM Providers {
  style.stroke: "#059669"
  style.border-radius: 8
  openai: OpenAI
  anthropic: Anthropic
  gemini: Google Gemini
}

# System Boundary
narrex: Narrex {
  style.stroke: "#0ea5e9"
  style.fill: "#f0f9ff"
  style.border-radius: 12
  style.font-size: 18

  label: |md
    **Narrex**
    Visual Novel Editor with AI Scene Generation
  |
}

# Data Flows
writer -> narrex: "Story ideas, timeline edits,\ncharacter management,\nAI generation triggers" {
  style.stroke: "#2563eb"
}
narrex -> writer: "Auto-structured timelines,\nAI-generated prose (SSE),\nedited drafts" {
  style.stroke: "#2563eb"
  style.stroke-dash: 5
}

narrex -> oauth: "Authentication requests" {
  style.stroke: "#9333ea"
}
oauth -> narrex: "OAuth tokens, user profile" {
  style.stroke: "#9333ea"
  style.stroke-dash: 5
}

narrex -> llm: "Assembled prompts\n(config + characters + context)" {
  style.stroke: "#059669"
}
llm -> narrex: "Generated prose tokens (stream)" {
  style.stroke: "#059669"
  style.stroke-dash: 5
}
